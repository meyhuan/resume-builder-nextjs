# AI Model API Keys (server-side only, never exposed to client)
# Copy this file to .env.local and fill in your keys

# OpenAI (for gpt-4o-mini)
OPENAI_API_KEY=

# Alibaba DashScope (optional fallback, for qwen-plus, qwen-max)
DASHSCOPE_API_KEY=

# Object Storage (Aliyun OSS)
ALIYUN_OSS_REGION=
ALIYUN_OSS_BUCKET=
ALIYUN_OSS_ENDPOINT=
ALIYUN_OSS_ACCESS_KEY_ID=
ALIYUN_OSS_ACCESS_KEY_SECRET=
ALIYUN_OSS_PUBLIC_BASE_URL=

# Google Analytics 4
# Get your measurement ID from https://analytics.google.com (format: G-XXXXXXXXXX)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
