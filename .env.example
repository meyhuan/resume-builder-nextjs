# Database
DATABASE_URL=

# AI Model API Keys (server-side only, never exposed to client)
# Copy this file to .env.local and fill in your keys

# Object Storage (Supabase Storage)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=resumes

# Alibaba DashScope (for qwen-plus, qwen-max)
DASHSCOPE_API_KEY=

# Analytics
NEXT_PUBLIC_BAIDU_ANALYTICS_ID=
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Java Backend API base URL (server-to-server, for VIP status sync)
# Default: https://aijianli.cn/api
JAVA_API_BASE_URL=

# Aliyun OSS (optional)
ALIYUN_OSS_REGION=
ALIYUN_OSS_BUCKET=
ALIYUN_OSS_HOSTNAME=
ALIYUN_OSS_ENDPOINT=
ALIYUN_OSS_ACCESS_KEY_ID=
ALIYUN_OSS_ACCESS_KEY_SECRET=
ALIYUN_OSS_PUBLIC_BASE_URL=
