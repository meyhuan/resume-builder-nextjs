# Database
DATABASE_URL=

# AI Model API Keys (server-side only, never exposed to client)
# Copy this file to .env.local and fill in your keys

# Object Storage (Supabase Storage)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=resumes

# Alibaba DashScope (for qwen-plus, qwen-max)
DASHSCOPE_API_KEY=

# Analytics
NEXT_PUBLIC_BAIDU_ANALYTICS_ID=
NEXT_PUBLIC_GA_MEASUREMENT_ID=
ANALYTICS_ADMIN_TOKEN=

# SEO URL submission
INDEXNOW_KEY=
INDEXNOW_KEY_LOCATION=https://aijianli.cn/indexnow.txt
BAIDU_PUSH_TOKEN=

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Java Backend API base URL.
# Used by both browser-side and server-side Java API calls.
# Required. Example: https://aijianli.cn/api
NEXT_PUBLIC_JAVA_API_BASE_URL=

# E2E / browser automation login shortcut.
# Local-only shortcut for screenshot automation.
# Works on localhost/127.0.0.1, including local production builds via next start.
# With E2E_AUTH_AUTO_LOGIN=true, opening any local page automatically signs in
# the fixed test account and then returns to that page.
E2E_AUTH_ENABLED=false
E2E_AUTH_AUTO_LOGIN=false
E2E_AUTH_SECRET=
E2E_AUTH_DEFAULT_WX_ID=e2e_default_user
E2E_AUTH_DEFAULT_REDIRECT=/m

# Aliyun OSS (optional)
ALIYUN_OSS_REGION=
ALIYUN_OSS_BUCKET=
ALIYUN_OSS_HOSTNAME=
ALIYUN_OSS_ENDPOINT=
ALIYUN_OSS_ACCESS_KEY_ID=
ALIYUN_OSS_ACCESS_KEY_SECRET=
ALIYUN_OSS_PUBLIC_BASE_URL=
