datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(cuid())
  clerkId   String?  @unique
  wxId      String?  @unique
  email     String?  @unique
  name      String?
  avatar    String?
  resumes   Resume[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Resume {
  id        String   @id @default(cuid())
  title     String
  content   Json
  template  String   @default("simple")
  thumbnail String?
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Template {
  id          String   @id
  name        String
  description String?
  thumbnail   String?  // Base64 or URL for the template snapshot
  config      Json?    // Optional extra configuration for the template
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
