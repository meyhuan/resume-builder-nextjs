datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id         String     @id @default(cuid())
  clerkId    String?    @unique
  wxId       String?    @unique  // Java tb_cvuser.id (auth_uid cookie value)
  javaUserId String?    @unique  // Java tb_user.id (VIP / payment system)
  email      String?    @unique
  name       String?
  avatar     String?
  resumes    Resume[]
  feedbacks  Feedback[]
  quotas     UserQuota[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

model Resume {
  id        String   @id @default(cuid())
  title     String
  content   Json
  template  String   @default("simple")
  thumbnail String?
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Feedback {
  id          String   @id @default(cuid())
  content     String   // The feedback text content
  contact     String?  // Optional contact info (email/phone/wechat)
  attachment  String?  // Optional base64 or URL for uploaded image/screenshot
  status      String   @default("RECEIVED")
  adminReply  String?
  adminReplyAt DateTime?
  likeCount   Int      @default(0)
  userId      String?  // Optional relation if user is logged in
  user        User?    @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
}

model UserQuota {
  userId    String   @id  // References User.id, one row per user
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  quotas    Json     @default("{}") // { "ai:generate-resume": { used: 5, date: "2025-01-15" }, ... }
  updatedAt DateTime @updatedAt
}
