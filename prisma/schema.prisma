datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String     @id @default(cuid())
  clerkId   String?    @unique
  wxId      String?    @unique
  email     String?    @unique
  name      String?
  avatar    String?
  resumes   Resume[]
  feedbacks Feedback[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Resume {
  id        String   @id @default(cuid())
  title     String
  content   Json
  template  String   @default("simple")
  thumbnail String?
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Feedback {
  id          String   @id @default(cuid())
  content     String   // The feedback text content
  contact     String?  // Optional contact info (email/phone/wechat)
  attachment  String?  // Optional base64 or URL for uploaded image/screenshot
  userId      String?  // Optional relation if user is logged in
  user        User?    @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
}
